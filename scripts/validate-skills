#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VALIDATOR_SOURCE="git+https://github.com/agentskills/agentskills#subdirectory=skills-ref"

if ! command -v uvx >/dev/null 2>&1; then
  echo "error: uvx is required to run the official agentskills validator." >&2
  echo "Install uv: https://docs.astral.sh/uv/getting-started/installation/" >&2
  exit 1
fi

shopt -s nullglob
skill_dirs=("$ROOT_DIR"/skills/*)

if [ "${#skill_dirs[@]}" -eq 0 ]; then
  echo "error: no skills found under skills/." >&2
  exit 1
fi

for skill_dir in "${skill_dirs[@]}"; do
  [ -d "$skill_dir" ] || continue
  uvx --from "$VALIDATOR_SOURCE" skills-ref validate "$skill_dir"
done

echo "validated ${#skill_dirs[@]} skills"
